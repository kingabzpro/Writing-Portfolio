---
import fs from "node:fs/promises";
import path from "node:path";
import type { LatestEntry } from "../types/content";

const latestPath = path.resolve(process.cwd(), "public/assets/data/latest.json");

let latest: LatestEntry[] = [];
try {
  const raw = await fs.readFile(latestPath, "utf-8");
  const parsed = JSON.parse(raw);
  if (Array.isArray(parsed)) {
    latest = parsed.slice(0, 3);
  }
} catch {
  latest = [];
}

function formatDate(value: string): string {
  if (!value) return "";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit"
  });
}
---

<section class="home-section">
  <h2>Latest Posts</h2>
  {
    latest.length === 0 ? (
      <p>No recent posts.</p>
    ) : (
      <ul class="latest-list">
        {latest.map((item) => (
          <li class="latest-item">
            <span class="latest-dot" aria-hidden="true"></span>
            <a
              class="latest-link"
              href={item.url}
              target="_blank"
              rel="noreferrer"
            >
              {item.title}
            </a>
            {item.date ? (
              <span class="latest-date">{formatDate(item.date)}</span>
            ) : null}
          </li>
        ))}
      </ul>
    )
  }
</section>
