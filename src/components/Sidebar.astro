---
import fs from "node:fs/promises";
import path from "node:path";

const PAGES_DIR = path.resolve(process.cwd(), "pages");
const articleLinkPattern = /-\s*\[(.*?)\]\((https?:\/\/[^)\s]+)\)/g;
const publicationNames: Record<string, string> = {
  analyticsvidhya: "Analytics Vidhya",
  datacamp: "DataCamp",
  firecrawl: "Firecrawl",
  freecodecamp: "freeCodeCamp",
  github: "GitHub",
  google: "Google",
  ibm: "IBM",
  kdnuggets: "KDnuggets",
  linkedin: "LinkedIn",
  machinelearningmastery: "Machine Learning Mastery",
  medium: "Medium",
  microsoft: "Microsoft",
  nexusml: "NexusML",
  nvidia: "NVIDIA",
  olostep: "Olostep",
  openai: "OpenAI",
  statology: "Statology",
  towardsdatascience: "Towards Data Science"
};

const categoryConfig = [
  { href: "/pages/python", label: "Python", slug: "python" },
  { href: "/pages/sql", label: "SQL", slug: "sql" },
  { href: "/pages/programming", label: "Programming", slug: "programming" },
  { href: "/pages/data-science", label: "Data Science", slug: "data-science" },
  { href: "/pages/machine-learning", label: "Machine Learning", slug: "machine-learning" },
  { href: "/pages/machine-learning-operations", label: "MLOps", slug: "machine-learning-operations" },
  { href: "/pages/natural-language-processing", label: "NLP", slug: "natural-language-processing" },
  { href: "/pages/large-language-models", label: "LLMs", slug: "large-language-models" },
  { href: "/pages/computer-vision", label: "Computer Vision", slug: "computer-vision" },
  { href: "/pages/artificial-intelligence", label: "AI", slug: "artificial-intelligence" },
  { href: "/pages/data-engineering", label: "Data Engineering", slug: "data-engineering" },
  { href: "/pages/career-advice", label: "Career", slug: "career-advice" },
  { href: "/pages/books-by-abid", label: "Books", slug: "books-by-abid" },
  { href: "/pages/cheat-sheets", label: "Cheat Sheets", slug: "cheat-sheets" }
];

async function countArticles(slug: string): Promise<number> {
  const filePath = path.join(PAGES_DIR, `${slug}.md`);

  try {
    const content = await fs.readFile(filePath, "utf-8");
    return Array.from(content.matchAll(articleLinkPattern)).length;
  } catch {
    return 0;
  }
}

function getPublication(url: string): string {
  try {
    const hostname = new URL(url).hostname.toLowerCase().replace(/^www\./, "");
    const parts = hostname.split(".");
    const domain =
      parts.length >= 3 && ["co", "com", "org", "net"].includes(parts.at(-2) ?? "")
        ? parts.at(-3)
        : parts.at(-2) ?? parts[0];

    if (!domain) return "External";
    return publicationNames[domain] ?? domain.replace(/-/g, " ").replace(/\b\w/g, (char) => char.toUpperCase());
  } catch {
    return "External";
  }
}

async function countPublications(): Promise<{ name: string; count: number }[]> {
  const counts = new Map<string, number>();
  const entries = await fs.readdir(PAGES_DIR, { withFileTypes: true });

  await Promise.all(
    entries
      .filter((entry) => entry.isFile() && entry.name.endsWith(".md"))
      .map(async (entry) => {
        const content = await fs.readFile(path.join(PAGES_DIR, entry.name), "utf-8");
        for (const match of content.matchAll(articleLinkPattern)) {
          const publication = getPublication(match[2]);
          counts.set(publication, (counts.get(publication) ?? 0) + 1);
        }
      })
  );

  return Array.from(counts, ([name, count]) => ({ name, count })).sort(
    (a, b) => b.count - a.count || a.name.localeCompare(b.name)
  );
}

const categories = (
  await Promise.all(
    categoryConfig.map(async (item) => ({
      ...item,
      articleCount: await countArticles(item.slug)
    }))
  )
).sort((a, b) => b.articleCount - a.articleCount || a.label.localeCompare(b.label));

const totalArticleCount = categories.reduce((total, item) => total + item.articleCount, 0);
const publications = await countPublications();
---

<aside id="sidebar" aria-label="Topic navigation">
  <div class="sidebar-heading">
    <h2>Categories</h2>
    <details class="sidebar-publication-menu">
      <summary class="sidebar-total" aria-label={`${totalArticleCount} articles across all categories. Expand articles by publication.`}>
        <span>{totalArticleCount}</span>
        <small>articles</small>
      </summary>
      <div class="sidebar-publications" aria-label="Articles by publication">
        {publications.map((item) => (
          <span class="sidebar-publication">
            <span>{item.name}</span>
            <strong>{item.count}</strong>
          </span>
        ))}
      </div>
    </details>
  </div>
  <p class="sidebar-subtitle">Sorted by article count</p>
  <ul>
    {
      categories.map((item) => (
        <li>
          <a href={item.href}>
            <span class="sidebar-label">{item.label}</span>
            {item.articleCount > 0 ? (
              <span class="sidebar-count" aria-label={`${item.articleCount} articles`}>
                {item.articleCount}
              </span>
            ) : null}
          </a>
        </li>
      ))
    }
  </ul>
</aside>
