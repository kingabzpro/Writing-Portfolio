---

<aside id="sidebar" aria-label="Topic navigation">
  <h2><i class="fas fa-folder-open"></i> Categories</h2>
  <ul>
    {
      categories.map((item) => (
        <li>
          <a href={item.href}>
            <i class={item.icon}></i>
            <span>{item.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</aside>
