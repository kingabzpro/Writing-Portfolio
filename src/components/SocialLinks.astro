---
import { Icon } from "astro-icon/components";
import type { SocialItem } from "../types/content";

interface Props {
  items: SocialItem[];
}

const { items } = Astro.props;
---

<div class="social-links">
  {
    items.map((item) => (
      <a href={item.url} target="_blank" rel="noreferrer" aria-label={item.platform}>
        <Icon name={item.icon} />
      </a>
    ))
  }
</div>
