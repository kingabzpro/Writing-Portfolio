---
import fs from "node:fs/promises";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import LatestPosts from "../components/LatestPosts.astro";
import SearchPanel from "../components/SearchPanel.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { SITE } from "../lib/seo";
import type { ContentData } from "../types/content";

const contentDataPath = path.resolve(process.cwd(), "public/assets/data/content.json");
const contentData = JSON.parse(await fs.readFile(contentDataPath, "utf-8")) as ContentData;
const miscItems = [
  {
    title: "Books Published by Abid",
    description: "A curated collection of books and ebooks focused on practical AI and data skills.",
    href: "/pages/books-by-abid"
  },
  {
    title: "Career Resources",
    description: "Interview prep, growth guidance, and actionable advice for building your data career.",
    href: "/pages/career-advice"
  },
  {
    title: "Cheat Sheets",
    description: "Fast, high-signal reference pages for core tools, workflows, and ML concepts.",
    href: "/pages/cheat-sheets"
  },
  {
    title: "Contact Me",
    description: "Reach out for collaboration, writing opportunities, or consulting conversations.",
    href: "/pages/contact"
  }
];
---

<BaseLayout title={SITE.title} description={SITE.description} pathname="/">
  <section class="author-section">
    <img src="/assets/images/author.jpg" alt="Abid profile picture" class="author-image" />
    <div class="author-bio">
      <h2 class="author-title">Hello, I'm Abid Ali Awan</h2>
      <p class="author-description">
        I am a certified data science professional with a passion for developing practical machine
        learning solutions. I have written more than 700 articles to make AI and data topics easier
        to learn and apply.
      </p>
      <p class="author-description">
        Reach out via the <a href="/pages/contact" class="highlight-link">contact page</a> or connect
        on LinkedIn.
      </p>
    </div>
  </section>

  <LatestPosts />
  <SearchPanel />

  <section class="home-section">
    <h2>Author Expertise</h2>
    <div class="content-grid">
      {
        contentData.expertise.map((item) => (
          <article class="content-card expertise-card">
            <h3>
              <i class={item.icon}></i>
              <span>{item.title}</span>
            </h3>
            <p>{item.description}</p>
            <a href={`/${item.link}`} class="inline-link">Learn More</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="home-section">
    <h2>Popular Topics</h2>
    <div class="topics-grid">
      {
        contentData.topics.map((topic) => (
          <a href={`/${topic.link}`} class="topic-btn">{topic.title}</a>
        ))
      }
    </div>
  </section>

  <section class="home-section">
    <h2>Miscellaneous</h2>
    <div class="misc-grid">
      {
        miscItems.map((item) => (
          <article class="content-card misc-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a href={item.href} class="inline-link">Learn More</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="cta-section">
    <h2>Stay Updated</h2>
    <p>
      Star this
      <a href="https://github.com/kingabzpro/Writing-Portfolio" target="_blank" rel="noreferrer">
        repository
      </a>
      to get notified about new updates.
    </p>
    <SocialLinks items={contentData.social} />
  </section>
</BaseLayout>
